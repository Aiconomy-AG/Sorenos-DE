      "rich_text_zmMkne": {
        "type": "rich-text",
        "settings": {
          "full_width": true,
          "section_title": "Starke Marken für starke Projekte",
          "text": "<p>Bei SORENOS GmbH setzen wir auf die besten Partner: 3M, Avery Dennison und SEEN. Diese weltweit führenden Marken stehen für höchste Qualitätsstandards, innovative Technologien und ein breites Produktportfolio, das keine Wünsche offenlässt. Dank dieser starken Partnerschaften können wir Ihnen Lösungen bieten, die in jedem Projekt überzeugen.</p>",
          "text_size": "medium"
        }
      },
