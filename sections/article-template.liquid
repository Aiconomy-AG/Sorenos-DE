<script>
  $(function() {
    var owl = $(".owl-carousel");
    owl.owlCarousel({
      items:1,
      margin: 10,
      dots:false,
      nav:true,
      loop: true,
      autoplay: true,
      autoplayTimeout:4000,
      slideSpeed : 2000,
      responsiveClass:true,
      autoHeight: true
    });
  });
</script>


