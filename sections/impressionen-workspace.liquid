{% style %}
  .playpause {
    pointer-events: auto;
    cursor: pointer;
    background-size: 90px;
    width: 100%;
    height: 100%;
  }
  .video-gallery video {
    min-height: 300px;
    object-fit: cover;
  }
  .video-bar.grid {
    display: flex;
    flex-direction: column;
    flex-wrap: wrap;
    justify-content: flex-start;
    gap: 16px;
  }
  .video-bar > .page-width {
    width: 100%;
    flex: 0 0 100%;
  }
  @media (max-width: 749px) {
    .video-bar .grid__item-wrapper {
      width: 100%;
    }
  }
{% endstyle %}

<div class="grid grid--no-gutters video-bar page-width">
  <div>
    <h3>{{ section.settings.heading }}</h3>
  </div>
  {% for block in section.blocks %}
    {%- assign poster_image = block.settings.image -%}
    {%- if poster_image == blank and block.settings.video != blank -%}
      {%- assign poster_image = block.settings.video.preview_image -%}
    {%- endif -%}
    <div class="grid__item-wrapper grid__item medium-up--one-half js" {{ block.shopify_attributes }}>
      <video
        class="videogrid"
        playsinline
        webkit-playsinline
        poster="{{ poster_image | img_url:'original' }}"
      >
        {%- if block.settings.videourl != blank -%}
          <source src="{{ block.settings.videourl }}" type="video/mp4">
        {%- elsif block.settings.video != blank -%}
          {%- for source in block.settings.video.sources -%}
            <source src="{{ source.url }}" type="{{ source.mime_type }}">
          {%- endfor -%}
        {%- endif -%}
      </video>
      <div class="playpause"></div>
    </div>
  {% endfor %}
</div>

{% schema %}
{
  "name": "Video Gallery (Workspace)",
  "class": "index-section index-section--flush video-gallery",
  "max_blocks": 16,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    }
  ],
  "blocks": [
    {
      "type": "video",
      "name": "video",
      "settings": [
        {
          "type": "text",
          "id": "videourl",
          "label": "Add video link"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Add thumbnail"
        },
        {
          "type": "header",
          "content": "OR"
        },
        {
          "type": "video",
          "id": "video",
          "label": "Add video"
        }
      ]
    }
  ]
}
{% endschema %}
<script>
  $(document).ready(function () {
    $('.grid__item-wrapper, .playpause').on('click', function (e) {
      e.stopPropagation();

      var wrapper = $(this).closest('.grid__item-wrapper');
      var video = wrapper.find('.videogrid').get(0);
      var button = wrapper.find('.playpause');

      $('.videogrid').each(function () {
        if (this !== video) {
          this.pause();
          this.removeAttribute('controls');
          $(this).siblings('.playpause').show();
        }
      });

      if (video.paused) {
        video.setAttribute('controls', 'controls');
        video.play();
        button.hide();
      } else {
        video.pause();
        video.removeAttribute('controls');
        button.show();
      }
    });

    $('.videogrid').on('pause ended', function () {
      this.removeAttribute('controls');
      $(this).siblings('.playpause').show();
    });

    $('.videogrid').on('play', function () {
      $(this).siblings('.playpause').hide();
    });
  });
</script>
