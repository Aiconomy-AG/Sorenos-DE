          $(document).ready(function(){


            set_input_data();
           


            /*===============Returns url parameters==========*/
            function get_url_params()
            {
              var url = decodeURI(window.location.href);
              if(url.includes("?"))
              {
              	  var url_parameters = url.split('?')[1].split('&');

    //            var url_string = 'https://www.folienzuschnitt.ch/pages/glas-stressanalyse-start';

                  var params = [];
                  for(let i = 0; i < url_parameters.length; i++)
                  {
                    var param_pair = url_parameters[i].split('=');
                    params[param_pair[0]] = param_pair[1].replaceAll('%20', ' ');
    //              params[url_string[i].split('=')[0]] = url_string[i];
                  } 
              	  return params;
              }
              return '';
            }

            /*===============Set url parameters==========*/
            function set_input_data(){

              var url_parameters = get_url_params();
              if(url_parameters !== '')
              {
                  $('.windowfilm1_select').val(url_parameters["material_id"]);
                  $('.glass-height').val(url_parameters["height"]);
                  $('.glass-width').val(url_parameters["width"]);
                  $('.glass-quantity').val(url_parameters["quantity"]);
                  $('.project-name').val(url_parameters["proj_name"]);
                  $('.piece_id').val(url_parameters["piece_id"]);
                  $('#meeresspiegel_google').val(url_parameters["above_sea_level"]);
                  if(url_parameters['location_typ'] == 'company_address' || url_parameters['location_typ'] == 'customer_address')
                  {
					$('#eb50it-Firmenadresse').trigger("click");
                       $('.hide-Montageort').removeClass('hide'); 
                       $('.Montageort-company').removeClass('hide');
                       $('.Montageort-address').addClass('hide'); 
                       $('#montageort_google').val(url_parameters["location"]);
                  }
                  else if(url_parameters['location_typ'] == 'privat_address')
                  {
					$('#eb50it-Privatadresse').trigger("click");
                    $('.hide-Montageort').removeClass('hide'); 
                    $('.Montageort-company').addClass('hide');
                    $('.Montageort-address').removeClass('hide');
                    $('#montageort_google_address').val(url_parameters["location"]);
                  }
                
                if($('.user-email').val() === '')
                {
                	$('.user-email').val(url_parameters["customer_email"]);
                }
              }
            }


