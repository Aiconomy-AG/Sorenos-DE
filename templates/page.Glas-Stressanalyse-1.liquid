<script>
  //https://developers.google.com/maps/documentation/javascript/examples/places-autocomplete-addressform#maps_places_autocomplete_addressform-javascript
let autocomplete;
let autocomplete_address;
let address1Field;
let postalField;

function initAutocomplete() {
  address1Field = document.querySelector("#montageort_google_address");
  companyField = document.querySelector("#montageort_google");
  
  // Create the autocomplete object, restricting the search predictions to
  // addresses in the US and Canada.
  autocomplete_address = new google.maps.places.Autocomplete(address1Field, {    
    fields: ["address_components", "geometry"],    
    types: ['address'],
  });
  autocomplete = new google.maps.places.Autocomplete(companyField, {    
    fields: ["address_components", "geometry"],    
    types: ['establishment'],
  });
  address1Field.focus();
  companyField.focus();
  // When the user selects an address from the drop-down, populate the
  // address fields in the form.
  autocomplete.addListener("place_changed", fillIncompany);
  autocomplete_address.addListener("place_changed", fillInAddress);
}
  
function fillInAddress() {
  // Get the place details from the autocomplete object.
  const place = autocomplete_address.getPlace();
  let address1 = "";
  let postcode = "";
  let montageortField = document.querySelector("#meeresspiegel_google");
  var gmarkers = [];
  var lat = place.geometry.location.lat();
  // get lng
  var lng = place.geometry.location.lng();
  
  //montageortField.value = lat + "," + lng;
//   console.log(place);
  
  var map = new google.maps.Map(
    document.getElementById("map_canvas"), {
      center: new google.maps.LatLng(lat, lng),      
      mapTypeId: "terrain",
    });
  var marker = new google.maps.Marker({
    position: map.getCenter(),
    map: map
  });
  gmarkers.push(marker);

  var elevationService = new google.maps.ElevationService();

  var requestElevation = {
    'locations': [gmarkers[0].getPosition()]
  };

  elevationService.getElevationForLocations(requestElevation, function(results, status) {
    
    if (status == google.maps.ElevationStatus.OK) {
      if (results[0]) {
        document.getElementById('meeresspiegel_google').value = parseFloat(results[0].elevation.toFixed(0)) + " Meter";
      }
    }
  });
  
  montageortField.focus();
}  

function fillIncompany() {
  // Get the place details from the autocomplete object.
  const place = autocomplete.getPlace();
  let address1 = "";
  let postcode = "";
  let montageortField = document.querySelector("#meeresspiegel_google");
  var gmarkers = [];
  var lat = place.geometry.location.lat();
  // get lng
  var lng = place.geometry.location.lng();
  
  //montageortField.value = lat + "," + lng;
//   console.log(place);
  
  var map = new google.maps.Map(
    document.getElementById("map_canvas"), {
      center: new google.maps.LatLng(lat, lng),      
      mapTypeId: "terrain",
    });
  var marker = new google.maps.Marker({
    position: map.getCenter(),
    map: map
  });
  gmarkers.push(marker);

  var elevationService = new google.maps.ElevationService();

  var requestElevation = {
    'locations': [gmarkers[0].getPosition()]
  };

  elevationService.getElevationForLocations(requestElevation, function(results, status) {
    
    if (status == google.maps.ElevationStatus.OK) {
      if (results[0]) {
        document.getElementById('meeresspiegel_google').value = parseFloat(results[0].elevation.toFixed(0)) + " Meter";
      }
    }
  });
  
  montageortField.focus();
} 
  
window.initAutocomplete = initAutocomplete;

</script>

