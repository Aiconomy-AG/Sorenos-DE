<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/localization/messages_de.js"></script>
  
<script>
  document.getElementById('form-more-windows-inner').addEventListener('click', function() {
    const formWrapper = document.getElementById('form-wrapper');
    const newIndex = formWrapper.getElementsByClassName('cform_field_wrapper').length + 1;

    const newForm = document.createElement('div');
    newForm.classList.add('cform_field_wrapper');
    newForm.innerHTML = `
      <div class="cform_fouritems">
    <div class="cform_fouritems-inner">
      <label for="field_${newIndex}">Glas Breite cm</label>
      <input type="text" id="field_${newIndex}" name="fenster[${newIndex}][glassWidth]" value="">
    </div>
    <div class="cform_fouritems-inner">
      <label for="field_${newIndex}">Glas Höhe cm</label>
      <input type="text" id="field_${newIndex}" name="fenster[${newIndex}][glassHeight]" value="">
    </div>
    <div class="cform_fouritems-inner">
      <span>Verglasung</span>
      <select name="fenster[${newIndex}][glazing]">
        <option value="">Bitte auswählen</option>
