  $(document).on('click','#send_form_data', function() {
    const $this = $(this);
    const $formWrapper = $('#form-wrapper');
    const $formItems = $formWrapper.find('.cform_field_wrapper');
    // Create a new FormData object
    var formData = new FormData();    
    var attributes = []; 
    var file_count = 0;
    
    $formItems.each(function(index, item) {
        let inputVal = 0;
        const $inputs = $(item).find('input, select, textarea');
        const windowData = {};
        var photos = [];      
        let indexval = index+1;
        
      
        $inputs.each(function(_, input) {            
            const name = $(input).attr('name'); 
            if(name){ 
                const finalname =  name.match(/\[([a-zA-Z_]+)\]$/)[1];                                      
                //console.log('finalname',finalname);                
              
                if(finalname == 'photos'){
                  var files = $('input[name="fenster['+indexval+'][photos]"]')[0].files;
                  // Check if the input has files
                  if (files && files.length > 0) {
                    for (var i = 0; i < files.length; i++) {
                        //formData.append('files[]', files[i]);
                        file_count++;
                        formData.append("file_" + file_count, files[i]);
                        //console.log(files[i]);                    
                    } 
                  }
                }
                else {
                  windowData[finalname] = $(input).val();
                }
              
                if($(input).val() !== '') {
                    inputVal++;
                }
            }
        });   
      
        if(inputVal > 0) {
            //formData[`fenster_${index + 1}`] = windowData;
        }
       
        attributes.push(windowData);
        
    });    
  
    const $contactFormWrapper = $('.contact-productpage-wrapper');
    const formValues = $contactFormWrapper.find('input, textarea').toArray().reduce((values, input) => {
        values[$(input).attr('name')] = $(input).val();
        return values;
    }, {});

    const contact = Object.keys(formValues).reduce((result, key) => {
        const newKey = key.replace(/^contact\[(.+)\]$/, '$1');
        result[newKey] = formValues[key];
        return result;
    }, {});

    var formValue = {
        "x-shopify-shop-domain": "{{ shop.permanent_domain }}",
        "emailTo": "info@sorenos.ch",
        "product": {
          "name": '',
          "quantity": '',
          "sku": ''
        },
        "attributes": attributes,
        "contactFields": contact        
    };

   
    $("form.offer_form").validate({
        lang: 'de',
        errorPlacement: function(error, element) {
            error.addClass("custom-error");
            error.appendTo(element.parent());
        },
        wrapper: 'div',
        highlight: function(element, errorClass, validClass) {
            $(element).addClass('error-highlight');
        },
        unhighlight: function(element, errorClass, validClass) {
            $(element).removeClass('error-highlight');
        }
    });

    if ($('form#offer_contact_form').valid()) {
     
      // Append structured data as JSON
      formData.append('file_count', file_count);
      formData.append('structuredData', JSON.stringify(formValue));
      //console.log(JSON.stringify(formValue));
      //console.log('file_count',file_count);
      
      $.ajax({
        url: "https://app.aico.swiss/67606625/api/product-offer-request-mail",        
        type: "POST",
        data: formData,        
        timeout: 0,
        contentType: false, // Important for multipart/form-data
        processData: false, // Don't process the data (jQuery defaults to processing as URL-encoded)    
        mimeType: "multipart/form-data",        
        cache: false,
        headers:{"Authorization": "Bearer wa1yz2iWhnsi9K14igUhU4OwFPMKEPIT0fKIE3nE061e3c6d"},
        beforeSend: function(){
          $this.addClass('loading');
          $this.find('.loading-overlay__spinner').removeClass('hidden');
          $this.attr('aria-disabled',true);
          $this.attr('disabled',true);
          $this.parents('.offer_form').find('div#form_error').addClass('hidden');
          $this.parents('.offer_form').find('div#form_success').addClass('hidden');
        },
        success: function (data) {
          $this.parents('.offer_form').find('div#form_success').removeClass('hidden');
          $('.contact-productpage-wrapper').find('input, textarea, select, file').val('');
          $('.cform_field_wrapper').find('input, textarea, select').val('');
          $('.cform_field_wrapper:not(:first-child)').remove();
          setTimeout(function(){
            $this.parents('.offer_form').find('div#form_error').addClass('hidden');
            $this.parents('.offer_form').find('div#form_success').addClass('hidden');
            $('.product-popup-modal__toggle').trigger('click');
          },3000);
        },
        complete:function(){
          $this.removeClass('loading');
          $this.find('.loading-overlay__spinner').addClass('hidden');
          $this.attr('aria-disabled',false);
          $this.attr('disabled',false);
        },
        error:function(jqXHR, textStatus, errorThrown ){
          $this.parents('.offer_form').find('div#form_error').removeClass('hidden');
        }
      });
    }
});

  $(document).ready(function() {

       $(document).on('change','#request-offer-modal .cform_fouritems select', function(event) {     
         if ($(this).val()) {
           $(this).addClass('selected');
         }
         else {
           $(this).removeClass('selected');
         }
      });
    
      $(document).on('click','.offer-wrap .btn-offerte', function(event) {
          event.preventDefault();
          $("#request-offer-modal").addClass('active');
          $("body").addClass('body_wrapper');
      });

      $(".product-popup-modal .modal__close").click(function(){
        $("#request-offer-modal").removeClass('active');
        $("body").removeClass('body_wrapper');
      });

      // Close popup when clicking outside of it
      $(document).on('mouseup touchstart', function(e) {
        var $popup = $('#request-offer-modal');       
        // If the target of the click isn't the popup or its descendants
        //!$popup.is(e.target) && 
        if ($popup.has(e.target).length === 0) {
          $popup.removeClass('active'); // Hide popup
          $("body").removeClass('body_wrapper'); // remove class from body
        }
      });

      $(".product-popup-modal .cform_fouritems .tooltip").mouseenter(function() {
          $(this).next().addClass('active');
      }).mouseleave(function() {
          $(this).next().removeClass('active');
      });
    
      /*$(".product-popup-modal .cform_fouritems .tooltip").on("click", function () {
         //$(".product-popup-modal .cform_fouritems .tooltip_content").removeClass('active');
         $(this).next().toggleClass('active');
      });*/
      
      $(document).on('change','.file_input', function() {
        const maxFiles = 3;
        const files = $(this).get(0).files;
        
        if (files.length > maxFiles) {
          alert(`Sie können nur maximal ${maxFiles} Dateien hochladen`);
          $(this).val(''); // Clear the selected files
        }
      });
    
  });
  
</script>