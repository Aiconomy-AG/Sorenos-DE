  </div>
  <div class="product-upload-photos-wrapper">
    <div class="cform_fouritems-inner input--line">
      <label for="field8">Mitteilung*</label>
      <textarea name="fenster[${newIndex}][remarks]" required></textarea>
    </div>
    <div class="cform_fouritems-inner input--button">
      <label for="field9">Fotos (max. 3) </label>
      <label for="file-upload_${newIndex}" class="custom-file-upload btn button">
            Fotos auswählen
      </label>
      <input
        id="file-upload_${newIndex}" 
        type="file"
